# Copy to .env and fill in real values. Never commit the real .env.
PORT=3000
DATABASE_URL="postgresql://cozypomo:changeme@localhost:5432/cozypomo?schema=public"
JWT_SECRET="changeme-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="changeme-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# Trang quản trị (/admin) — đăng nhập bằng cặp email/mật khẩu này
ADMIN_EMAIL="admin@cozypomo.dev"
ADMIN_PASSWORD="changeme-admin-password"
ADMIN_COOKIE_SECRET="changeme-random-long-string"

# docker-compose only
DB_PASSWORD="changeme"
